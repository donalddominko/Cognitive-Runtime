# Copy this file to .env and fill in values before running docker compose.
# Defaults shown here work for the standard Docker setup out of the box.

# Docker Configuration
NODE_ENV=production
POSTGRES_USER=cognitive
POSTGRES_PASSWORD=cognitive
POSTGRES_DB=cognitive_runtime
API_PORT=3001
WEB_PORT=3000
WEB_DEV_PORT=5173

# Service URLs (Docker internal network — do not change unless you know why)
DATABASE_URL=postgresql://cognitive:cognitive@postgres:5432/cognitive_runtime
QDRANT_URL=http://qdrant:6333
LLAMA_URL=http://llama:8080

# Frontend (must be reachable from the browser, not from inside Docker)
VITE_API_URL=http://localhost:3001

# Optional: Qwen model configuration
QWEN_CONTEXT_SIZE=8192
QWEN_MAX_TOKENS=2048

# Phase 5.1: Embedding + Cache
EMBEDDING_PROVIDER=llama_cpp
EMBEDDING_ALLOW_DEV_FALLBACK=true
REDIS_ENABLED=true
CACHE_EMBEDDINGS=true
CACHE_RETRIEVAL=false
CACHE_WORKING_CONTEXT=true
